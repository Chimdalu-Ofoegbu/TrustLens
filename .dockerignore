.git
.planning
.claude
.venv
# **/ required: bare patterns match only at the context root, so nested
# bytecode inside the COPY'd packages would ship in the image (WR-02).
**/__pycache__
**/*.py[cod]
.pytest_cache
.coverage
htmlcov
*.egg-info
tests
web/dist
data/*.db
data/*.db-wal
data/*.db-shm
data/cache
.env
